{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "dotnet-format-style",
      "command": "dotnet",
      "args": ["format", "Zametek.ProjectPlan.slnf", "style", "--verify-no-changes", "--verbosity", "quiet"]
    },
    {
      "name": "dotnet-format-analyzers",
      "command": "dotnet",
      "args": ["format", "Zametek.ProjectPlan.slnf", "analyzers", "--verify-no-changes", "--verbosity", "quiet"]
    },
    {
      "name": "dotnet-build",
      "command": "dotnet",
      "args": ["build", "Zametek.ProjectPlan.slnf", "--no-restore", "--configuration", "Debug", "--verbosity", "quiet"]
    },
    {
      "name": "dotnet-test",
      "command": "dotnet",
      "args": ["test", "Zametek.ProjectPlan.slnf", "--no-build", "--configuration", "Debug", "--verbosity", "quiet"]
    }
  ]
}
