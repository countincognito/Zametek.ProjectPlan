<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:resources="using:Zametek.Resource.ProjectPlan"
			 xmlns:local="using:Zametek.View.ProjectPlan"
			 xmlns:vm="using:Zametek.ViewModel.ProjectPlan"
			 xmlns:i="using:Avalonia.Xaml.Interactivity"
	         xmlns:ia="clr-namespace:Avalonia.Xaml.Interactions.Core;assembly=Xaml.Behaviors.Interactions"
			 x:DataType="vm:ProjectManagerViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Zametek.View.ProjectPlan.ProjectManagerView">
	<UserControl.Resources>
	</UserControl.Resources>

	<DockPanel Margin="7">
		<ScrollViewer DockPanel.Dock="Right"
			  VerticalScrollBarVisibility="Hidden"
			  HorizontalScrollBarVisibility="Disabled">
			<DockPanel Margin="11,0,0,0">
				<Button DockPanel.Dock="Top"
						IsTabStop="True"
						Margin="0,0,0,7"
						Height="25" Width="80"
						VerticalAlignment="Center"
						VerticalContentAlignment="Center"
						Command="{Binding Path=LoadProjectPlanFileCommand, Mode=OneWay}"
						Content="{x:Static resources:Labels.Label_LoadManagedPlan}"/>

				<Button DockPanel.Dock="Top"
						IsTabStop="True"
						Margin="0,0,0,7"
						Height="25" Width="80"
						VerticalAlignment="Center"
						VerticalContentAlignment="Center"
						Command="{Binding Path=BranchProjectPlanFileCommand, Mode=OneWay}"
						Content="{x:Static resources:Labels.Label_BranchManagedPlan}"/>

				<Button DockPanel.Dock="Top"
						IsTabStop="True"
						Margin="0,0,0,7"
						Height="25" Width="80"
						VerticalAlignment="Center"
						VerticalContentAlignment="Center"
						Command="{Binding Path=SpawnProjectPlanFileCommand, Mode=OneWay}"
						Content="{x:Static resources:Labels.Label_SpawnManagedPlan}"/>

				<Button DockPanel.Dock="Top"
						IsTabStop="True"
						Margin="0,0,0,7"
						Height="25" Width="80"
						VerticalAlignment="Center"
						VerticalContentAlignment="Center"
						Command="{Binding Path=AddProjectPlanTagCommand, Mode=OneWay}"
						Content="{x:Static resources:Labels.Label_AddTag}"/>

				<Button DockPanel.Dock="Top"
						IsTabStop="True"
						Margin="0,0,0,7"
						Height="25" Width="80"
						VerticalAlignment="Center"
						VerticalContentAlignment="Center"
						Command="{Binding Path=RemoveProjectPlanTagCommand, Mode=OneWay}"
						Content="{x:Static resources:Labels.Label_DeleteTag}"/>

				<Grid/>
			</DockPanel>
		</ScrollViewer>
		
		<TreeView Name="planTree"
				  ItemsSource="{Binding Path=Plans, Mode=OneWay}"
				  SelectedItems="{Binding Path=SelectedPlans, Mode=OneWay}"
				  SelectionMode="Multiple">
			<TreeView.Styles>
				<Style Selector="TreeViewItem" x:DataType="vm:ManagedPlanViewModel">
					<Setter Property="IsExpanded" Value="True" />
				</Style>
				<Style Selector="TextBlock.isLoaded" x:DataType="vm:ManagedPlanViewModel">
					<Setter Property="FontWeight" Value="Bold" />
				</Style>
			</TreeView.Styles>
			
			<TreeView.ItemTemplate>
				<TreeDataTemplate ItemsSource="{Binding Path=Children, Mode=OneWay}">
					<TextBlock Text="{Binding Path=Label, Mode=OneWay}"
							   Classes.isLoaded="{Binding Path=IsLoaded, Mode=OneWay}">
					</TextBlock>
				</TreeDataTemplate>
			</TreeView.ItemTemplate>

			<i:Interaction.Behaviors>
				<ia:EventTriggerBehavior EventName="SelectionChanged" SourceObject="{Binding #planTree}">
					<ia:InvokeCommandAction Command="{Binding Path=SetSelectedManagedPlansCommand, Mode=OneWay}" PassEventArgsToCommand="True" />
				</ia:EventTriggerBehavior>
				<ia:EventTriggerBehavior EventName="DoubleTapped" SourceObject="{Binding #planTree}">
					<ia:InvokeCommandAction Command="{Binding Path=LoadProjectPlanFileCommand, Mode=OneWay}" PassEventArgsToCommand="False" />
				</ia:EventTriggerBehavior>
			</i:Interaction.Behaviors>
		</TreeView>
	</DockPanel>
</UserControl>
