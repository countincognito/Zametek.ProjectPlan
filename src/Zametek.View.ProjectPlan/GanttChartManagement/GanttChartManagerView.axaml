<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:resources="using:Zametek.Resource.ProjectPlan"
			 xmlns:local="using:Zametek.View.ProjectPlan"
			 xmlns:scottplot="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
			 xmlns:vm="using:Zametek.ViewModel.ProjectPlan"
			 xmlns:common="using:Zametek.Common.ProjectPlan"
			 x:DataType="vm:GanttChartManagerViewModel"
			 xmlns:sys="using:System"
			 xmlns:u="https://irihi.tech/ursa"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Zametek.View.ProjectPlan.GanttChartManagerView">
	<UserControl.Resources>
	</UserControl.Resources>

	<DockPanel Margin="7">
		<ScrollViewer DockPanel.Dock="Right"
					  VerticalScrollBarVisibility="Hidden"
					  HorizontalScrollBarVisibility="Disabled">
			<DockPanel Margin="11,0,0,0"
					   Width="120">
				<DockPanel DockPanel.Dock="Top">
					<Label VerticalContentAlignment="Center"
						   HorizontalContentAlignment="Left"
						   Height="25"
						   DockPanel.Dock="Top"
						   IsTabStop="False"
						   Margin="0,0,0,3"
						   Content="{x:Static resources:Labels.Label_GroupByMode}"/>

					<ComboBox ItemsSource="{Binding Source={local:EnumBindingSource {x:Type common:GroupByMode}}}"
							  SelectedItem="{Binding Path=GroupByMode, Mode=TwoWay}"
							  BorderBrush="Gray"
							  BorderThickness="1"
							  DockPanel.Dock="Top"
							  IsTabStop="False"
							  Margin="0,0,0,11"
							  Height="25">
						<ComboBox.ItemTemplate>
							<DataTemplate>
								<TextBlock VerticalAlignment="Center"
										   TextAlignment="Left"
										   Margin="0"
										   Padding="3"
										   Text="{Binding Converter={x:Static local:StringConverters.GroupByModeValue}, Mode=OneWay}"/>
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
				</DockPanel>

				<DockPanel DockPanel.Dock="Top">
					<Label VerticalContentAlignment="Center"
						   HorizontalContentAlignment="Left"
						   Height="25"
						   DockPanel.Dock="Top"
						   IsTabStop="False"
						   Margin="0,0,0,3"
						   Content="{x:Static resources:Labels.Label_AnnotationStyle}"/>

					<ComboBox ItemsSource="{Binding Source={local:EnumBindingSource {x:Type common:AnnotationStyle}}}"
							  SelectedItem="{Binding Path=AnnotationStyle, Mode=TwoWay}"
							  BorderBrush="Gray"
							  BorderThickness="1"
							  DockPanel.Dock="Top"
							  IsTabStop="False"
							  Margin="0,0,0,11"
							  Height="25">
						<ComboBox.ItemTemplate>
							<DataTemplate>
								<TextBlock VerticalAlignment="Center"
										   TextAlignment="Left"
										   Margin="0"
										   Padding="3"
										   Text="{Binding Converter={x:Static local:StringConverters.AnnotationStyleValue}, Mode=OneWay}"/>
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
				</DockPanel>

				<DockPanel DockPanel.Dock="Top">
					<Label VerticalContentAlignment="Center"
						   HorizontalContentAlignment="Left"
						   Height="25"
						   DockPanel.Dock="Top"
						   IsTabStop="False"
						   Margin="0,0,0,3"
						   Content="{x:Static resources:Labels.Label_ShowConnections}"/>

					<u:MultiComboBox MaxHeight="200"
									 Width="{x:Static sys:Double.NaN}"
									 HorizontalAlignment="Stretch"
									 VerticalAlignment="Stretch"
									 Focusable="True"
									 Height="25"
									 ItemsSource="{Binding Path=ActivitySelector.TargetActivities, Mode=OneWay}"
									 SelectedItems="{Binding Path=ActivitySelector.SelectedTargetActivities, Mode=OneWay}">
						<u:MultiComboBox.SelectedItemTemplate>
							<DataTemplate x:DataType="vm:SelectableActivityViewModel">
								<Grid>
									<TextBlock Text="{Binding Path=Id, Mode=OneWay}"/>
								</Grid>
							</DataTemplate>
						</u:MultiComboBox.SelectedItemTemplate>
						<u:MultiComboBox.ItemTemplate>
							<DataTemplate x:DataType="vm:SelectableActivityViewModel">
								<Grid>
									<TextBlock Text="{Binding Path=Id, Mode=OneWay}"
											   ToolTip.Tip="{Binding Path=DisplayName, Mode=OneWay}"/>
								</Grid>
							</DataTemplate>
						</u:MultiComboBox.ItemTemplate>
					</u:MultiComboBox>
				</DockPanel>

				<Grid/>
			</DockPanel>
		</ScrollViewer>

		<DockPanel>
			<!-- ScottPlot PlotView -->
			<ContentControl x:Name="scottplot"
							Content="{Binding GanttChartPlotModel, Mode=OneWay}"
							Bounds="{Binding Path=ImageBounds, Mode=OneWayToSource}">
				<ContentControl.ContextMenu>
					<ContextMenu>
						<MenuItem Header="{x:Static resources:Labels.Label_ShowGroupLabels}"
								  IsEnabled="{Binding Path=IsAnnotated, Mode=OneWay}"
								  IsChecked="{Binding Path=ShowGroupLabels, Mode=TwoWay}"
								  ToggleType="CheckBox" />

						<MenuItem Header="{x:Static resources:Labels.Label_ShowSlack}"
								  IsEnabled="{Binding Path=IsAnnotated, Mode=OneWay}"
								  IsChecked="{Binding Path=ShowSlack, Mode=TwoWay}"
								  ToggleType="CheckBox" />

						<MenuItem Header="{x:Static resources:Labels.Label_ShowProjectFinish}"
								  IsChecked="{Binding Path=ShowProjectFinish, Mode=TwoWay}"
								  ToggleType="CheckBox" />

						<MenuItem Header="{x:Static resources:Labels.Label_ShowTracking}"
								  IsChecked="{Binding Path=ShowTracking, Mode=TwoWay}"
								  ToggleType="CheckBox" />

						<MenuItem Header="{x:Static resources:Labels.Label_ShowToday}"
								  IsChecked="{Binding Path=ShowToday, Mode=TwoWay}"
								  ToggleType="CheckBox" />

						<MenuItem Header="{x:Static resources:Labels.Label_ShowMilestones}"
								  IsChecked="{Binding Path=ShowMilestones, Mode=TwoWay}"
								  ToggleType="CheckBox" />
						
						<Separator />

						<MenuItem Header="{x:Static resources:Menus.Menu_SaveAs}"
								  Command="{Binding Path=SaveGanttChartImageFileCommand, Mode=OneWay}" />

						<MenuItem Header="{x:Static resources:Menus.Menu_Reset}"
								  Command="{Binding Path=ResetGanttChartCommand, Mode=OneWay}" />
					</ContextMenu>
				</ContentControl.ContextMenu>
			</ContentControl>
		</DockPanel>
	</DockPanel>
</UserControl>
