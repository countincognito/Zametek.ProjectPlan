<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:g="using:Zametek.Graphs.ProjectPlan"
			 xmlns:vm="using:Zametek.ViewModel.ProjectPlan"
			 x:DataType="vm:ArrowGraphManagerViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Zametek.View.ProjectPlan.ArrowGraphManagerView">

  <!-- The interactive viewer lives in the reusable Zametek.Graphs.ProjectPlan control library.
       It binds to IInteractiveArrowGraph, which ArrowGraphManagerViewModel implements, and
       inherits this view's DataContext (the manager view-model). -->
  <g:InteractiveArrowGraphView Margin="7"/>

</UserControl>
