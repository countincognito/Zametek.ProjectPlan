<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:g="using:Zametek.Graphs.ProjectPlan"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             x:DataType="g:IInteractiveArrowGraph"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Zametek.Graphs.ProjectPlan.InteractiveArrowGraphView">
  <UserControl.Resources>
    <g:ThemeToBackgroundConverter x:Key="themeToBackgroundConverter"/>
  </UserControl.Resources>

  <DockPanel>
    <DockPanel Width="250"
               DockPanel.Dock="Top">
      <TextBlock Margin="0,11,11,11"
                 DockPanel.Dock="Right"
                 Text="x"/>
      <TextBlock Margin="0,11,0,11"
                 DockPanel.Dock="Right"
                 Text="{Binding ElementName=zoomer, Path=Value, Mode=OneWay, StringFormat=\{0:N1\}}"/>
      <Slider Name="zoomer"
              Orientation="Horizontal"
              Value="1"
              PointerWheelChanged="Zoom_PointerWheelChanged"
              ValueChanged="Slider_ValueChanged"
              Minimum="0.1" Maximum="5"
              Margin="11"/>
    </DockPanel>

    <!-- Viewport: clips the content; dragging the background pans, the wheel/slider zoom.
         Panning is unbounded (a render transform, not a scroll region), so nodes dragged
         anywhere stay reachable. -->
    <Border Name="viewport"
            ClipToBounds="True"
            Background="{Binding Path=BaseTheme, Mode=OneWay, Converter={StaticResource themeToBackgroundConverter}}"
            PointerPressed="Viewport_PointerPressed"
            PointerMoved="Viewport_PointerMoved"
            PointerReleased="Viewport_PointerReleased"
            PointerWheelChanged="Zoom_PointerWheelChanged">
      <Border.ContextMenu>
        <ContextMenu>
          <MenuItem Header="{x:Static g:Menus.Menu_FitToView}"
                    Click="FitToView_Click"/>
          <MenuItem Header="{x:Static g:Menus.Menu_ResetGraphLayout}"
                    Click="ResetLayout_Click"/>
          <Separator/>
          <MenuItem Header="{x:Static g:Menus.Menu_ShowNames}"
                    IsChecked="{Binding Path=ShowNames, Mode=TwoWay}"
                    ToggleType="CheckBox"/>
          <MenuItem Header="{x:Static g:Menus.Menu_SaveAs}"
                    Command="{Binding Path=SaveArrowGraphImageFileCommand, Mode=OneWay}"/>
        </ContextMenu>
      </Border.ContextMenu>

      <!-- panLayer carries the pan TranslateTransform (assigned in code-behind);
           graphCanvas carries the zoom ScaleTransform (bound to the slider). -->
      <Canvas Name="panLayer" RenderTransformOrigin="0,0">
        <Canvas Name="graphCanvas"
                Width="{Binding Path=WorkspaceWidth, Mode=OneWay}"
                Height="{Binding Path=WorkspaceHeight, Mode=OneWay}"
                ClipToBounds="False"
                RenderTransformOrigin="0,0"
                SizeChanged="GraphCanvas_SizeChanged">
          <Canvas.RenderTransform>
            <ScaleTransform ScaleX="{Binding Value, ElementName=zoomer, Mode=OneWay}"
                            ScaleY="{Binding Value, ElementName=zoomer, Mode=OneWay}"/>
          </Canvas.RenderTransform>

          <!-- Edges drawn underneath the nodes. Sized so the items panel arranges
               (ClipToBounds is false, so nodes dragged beyond still render). -->
          <ItemsControl ItemsSource="{Binding Path=GraphEdges, Mode=OneWay}"
                        Width="{Binding Path=WorkspaceWidth, Mode=OneWay}"
                        Height="{Binding Path=WorkspaceHeight, Mode=OneWay}"
                        ClipToBounds="False">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <Canvas/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="g:ArrowGraphEdgeViewModel">
                <Canvas>
                  <!-- Invisible wide hit area so the thin activity line is easy to hover for its
                       tooltip. Transparent (not null) so it is hit-test visible. -->
                  <Line StartPoint="{Binding Path=StartPoint, Mode=OneWay}"
                        EndPoint="{Binding Path=EndPoint, Mode=OneWay}"
                        Stroke="Transparent"
                        StrokeThickness="14"
                        ToolTip.Tip="{Binding Path=Tooltip, Mode=OneWay}"/>
                  <Line StartPoint="{Binding Path=StartPoint, Mode=OneWay}"
                        EndPoint="{Binding Path=EndPoint, Mode=OneWay}"
                        Stroke="{Binding Path=Stroke, Mode=OneWay}"
                        StrokeThickness="{Binding Path=StrokeThickness, Mode=OneWay}"
                        StrokeDashArray="{Binding Path=StrokeDashArray, Mode=OneWay}"
                        Opacity="{Binding Path=EdgeOpacity, Mode=OneWay}"
                        IsHitTestVisible="False"/>
                  <Polygon Points="{Binding Path=ArrowPoints, Mode=OneWay}"
                           Fill="{Binding Path=Stroke, Mode=OneWay}"
                           Opacity="{Binding Path=EdgeOpacity, Mode=OneWay}"
                           ToolTip.Tip="{Binding Path=Tooltip, Mode=OneWay}"/>
                  <!-- Activity label, lifted just off the line at the edge midpoint. -->
                  <TextBlock Canvas.Left="{Binding Path=LabelX, Mode=OneWay}"
                             Canvas.Top="{Binding Path=LabelY, Mode=OneWay}"
                             Text="{Binding Path=Label, Mode=OneWay}"
                             IsVisible="{Binding Path=ShowLabel, Mode=OneWay}"
                             Foreground="{Binding Path=LabelBrush, Mode=OneWay}"
                             Opacity="{Binding Path=EdgeOpacity, Mode=OneWay}"
                             FontFamily="Consolas"
                             FontSize="12"
                             ToolTip.Tip="{Binding Path=Tooltip, Mode=OneWay}"/>
                </Canvas>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Event nodes: draggable, selectable, with hover tooltips. -->
          <ItemsControl ItemsSource="{Binding Path=GraphNodes, Mode=OneWay}"
                        Width="{Binding Path=WorkspaceWidth, Mode=OneWay}"
                        Height="{Binding Path=WorkspaceHeight, Mode=OneWay}"
                        ClipToBounds="False">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <Canvas/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.Styles>
              <Style Selector="ContentPresenter" x:DataType="g:ArrowGraphNodeViewModel">
                <Setter Property="Canvas.Left" Value="{Binding Path=X, Mode=OneWay}"/>
                <Setter Property="Canvas.Top" Value="{Binding Path=Y, Mode=OneWay}"/>
              </Style>
            </ItemsControl.Styles>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="g:ArrowGraphNodeViewModel">
                <Grid Width="{Binding Path=Width, Mode=OneWay}"
                      Height="{Binding Path=Height, Mode=OneWay}"
                      Opacity="{Binding Path=NodeOpacity, Mode=OneWay}"
                      Background="Transparent"
                      Cursor="Hand"
                      ToolTip.Tip="{Binding Path=Tooltip, Mode=OneWay}">
                  <i:Interaction.Behaviors>
                    <g:ArrowNodeDragBehavior/>
                  </i:Interaction.Behaviors>
                  <!-- Node body: fill + slack/override border, dashed for critical/dummy. -->
                  <Rectangle Fill="{Binding Path=FillBrush, Mode=OneWay}"
                             Stroke="{Binding Path=BorderBrush, Mode=OneWay}"
                             StrokeThickness="{Binding Path=BorderThickness, Mode=OneWay}"
                             StrokeDashArray="{Binding Path=StrokeDashArray, Mode=OneWay}"
                             RadiusX="3" RadiusY="3"/>
                  <!-- Selection ring: sits over the body so it never hides the slack colour. -->
                  <Rectangle Stroke="#0078D4"
                             StrokeThickness="3"
                             RadiusX="3" RadiusY="3"
                             IsHitTestVisible="False"
                             IsVisible="{Binding Path=IsSelected, Mode=OneWay}"/>
                  <TextBlock Text="{Binding Path=Label, Mode=OneWay}"
                             FontFamily="Consolas"
                             FontSize="11"
                             Foreground="Black"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             IsHitTestVisible="False"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Canvas>
      </Canvas>
    </Border>
  </DockPanel>
</UserControl>
